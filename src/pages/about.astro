---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Card from "../components/ui/Card.astro";
import site from "../data/site.json";
import skills from "../data/skills.json";
---

<BaseLayout title="About | Portfolio" description={site.about.bio}>
  <Container className="py-14 sm:py-16">
    <SectionTitle as="h1" title="About" subtitle={site.about.bio} />

    <section aria-labelledby="approach" class="mb-12">
      <h2 id="approach" class="mb-4 text-xl font-semibold">How I work</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <Card>
          <h3 class="font-semibold">Problems I solve</h3>
          <p class="mt-3 text-sm text-[var(--muted)]">{site.about.problemsSolved}</p>
        </Card>
        <Card>
          <h3 class="font-semibold">Engineering approach</h3>
          <p class="mt-3 text-sm text-[var(--muted)]">{site.about.engineeringApproach}</p>
        </Card>
      </div>
    </section>

    <section aria-labelledby="values" class="mb-12">
      <h2 id="values" class="mb-4 text-xl font-semibold">What I value</h2>
      <Card>
        <ul class="grid gap-2 text-sm text-[var(--muted)] sm:grid-cols-2">
          {site.about.values.map((value) => <li>• {value}</li>)}
        </ul>
      </Card>
    </section>

    <section aria-labelledby="skills" class="mb-12">
      <h2 id="skills" class="mb-4 text-xl font-semibold">Skills</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          skills.map((skillGroup) => (
            <Card>
              <h3 class="font-semibold">{skillGroup.category}</h3>
              <ul class="mt-3 flex flex-wrap gap-2">
                {skillGroup.items.map((skill) => <li class="rounded bg-neutral-100 px-2 py-1 text-xs">{skill}</li>)}
              </ul>
            </Card>
          ))
        }
      </div>
    </section>

    <section aria-labelledby="timeline">
      <h2 id="timeline" class="mb-4 text-xl font-semibold">Timeline</h2>
      <div class="space-y-4">
        {
          site.about.timeline.map((item) => (
            <Card>
              <p class="text-xs text-[var(--muted)]">{item.period}</p>
              <h3 class="mt-1 font-semibold">{item.title}</h3>
              <p class="mt-2 text-sm text-[var(--muted)]">{item.summary}</p>
            </Card>
          ))
        }
      </div>
    </section>
  </Container>
</BaseLayout>
