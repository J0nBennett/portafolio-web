---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import ProjectFilters from "../../components/projects/ProjectFilters.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allTags = [...new Set(projects.flatMap((project) => project.data.tags))].sort();
---

<BaseLayout
  title="Proyectos | Portfolio"
  description="Listado de proyectos con enfoque de ingeniería."
  image="/og/projects.png"
>
  <Container className="py-16 sm:py-20">
    <div class="scroll-reveal">
      <SectionTitle
        as="h1"
        title="Proyectos"
        subtitle="Cada proyecto documenta problema, solución y decisiones técnicas."
      />
    </div>
    <div class="scroll-reveal">
      <ProjectFilters tags={allTags} />
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project, i) => (
          <div data-project-card data-tags={project.data.tags.join(",")} class={`scroll-reveal stagger-${(i % 6) + 1}`}>
            <ProjectCard project={project.data} slug={project.slug} />
          </div>
        ))
      }
    </div>
  </Container>
</BaseLayout>
