---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Button from "../components/ui/Button.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import site from "../data/site.json";

const projects = await getCollection("projects");
const featured = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title={`${site.siteName} | Home`} description={site.description} image="/og/home.png">
  <Container className="py-16 sm:py-24">
    <section class="grid gap-8 rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-8 sm:grid-cols-[1.45fr_1fr]">
      <div>
        <p class="text-sm uppercase tracking-wider text-[var(--muted)]">{site.roles.join(" | ")}</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">{site.author}</h1>
        <p class="mt-4 max-w-2xl text-lg text-[var(--muted)]">{site.tagline}</p>
        <p class="mt-5 text-sm font-medium">How I work</p>
        <ul class="mt-2 space-y-2 text-sm text-[var(--muted)]">
          {site.home.differentiators.map((item) => <li>• {item}</li>)}
        </ul>
        <div class="mt-7 flex flex-wrap gap-3">
          <Button href={site.home.primaryCta.href}>{site.home.primaryCta.label}</Button>
          <Button href={site.home.secondaryCta.href} variant="secondary">
            {site.home.secondaryCta.label}
          </Button>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {site.focusAreas.map((area) => <span class="rounded bg-neutral-100 px-2 py-1 text-xs text-neutral-700">{area}</span>)}
        </div>
      </div>
      <ul class="grid gap-4">
        {
          site.home.highlights.map((item) => (
            <li class="rounded-xl border border-[var(--border)] bg-white p-4">
              <p class="text-2xl font-semibold">{item.value}</p>
              <p class="text-sm text-[var(--muted)]">{item.label}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </Container>

  <Container className="pb-16">
    <SectionTitle
      title="Featured Projects"
      subtitle="Selección de entregas con foco en arquitectura, rendimiento y mantenibilidad."
    />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project) => <ProjectCard project={project.data} slug={project.slug} />)}
    </div>
  </Container>
</BaseLayout>
