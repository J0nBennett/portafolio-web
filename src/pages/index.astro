---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Button from "../components/ui/Button.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import site from "../data/site.json";

const projects = await getCollection("projects");
const featured = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title={`${site.siteName} | Home`} description={site.description} image="/og/home.png">
  <!-- Hero -->
  <!-- Hero -->
  <Container className="pt-12 pb-12 sm:pt-32 sm:pb-24">
    <section class="relative">
      <!-- Decorative orb -->
      <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-cyan-500/10 blur-[100px] animate-float"></div>
      <div class="pointer-events-none absolute -left-16 top-32 h-56 w-56 rounded-full bg-violet-500/10 blur-[80px] animate-float delay-3"></div>

      <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-center">
        <!-- Left: Text content -->
        <div>
          <div class="animate-fade-in-up">
            <p class="inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-4 py-1.5 text-sm text-cyan-400">
              <span class="h-2 w-2 rounded-full bg-cyan-400 animate-pulse"></span>
              {site.roles.join(" · ")}
            </p>
          </div>

          <h1 class="mt-6 text-3xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl animate-fade-in-up delay-1">
            <span class="text-[var(--text-heading)]">Hola, soy </span>
            <span class="gradient-text">{site.author}</span>
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-relaxed text-[var(--muted)] animate-fade-in-up delay-2">
            {site.tagline}
          </p>

          <!-- How I work -->
          <div class="mt-8 animate-fade-in-up delay-3">
            <p class="text-sm font-semibold text-[var(--text-heading)] uppercase tracking-wider">How I work</p>
            <ul class="mt-3 space-y-2 text-sm text-[var(--muted)]">
              {site.home.differentiators.map((item, i) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-wrap gap-3 animate-fade-in-up delay-4">
            <Button href={site.home.primaryCta.href}>{site.home.primaryCta.label}</Button>
            <Button href={site.home.secondaryCta.href} variant="secondary">
              {site.home.secondaryCta.label}
            </Button>
          </div>

          <!-- Focus areas -->
          <div class="mt-8 flex flex-wrap gap-2 animate-fade-in-up delay-5">
            {site.focusAreas.map((area) => (
              <span class="rounded-lg border border-white/[0.06] bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-[var(--muted)] transition-colors duration-200 hover:border-cyan-500/20 hover:text-cyan-400">
                {area}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Stat highlights -->
        <div class="grid gap-4 animate-fade-in-up delay-4">
          {
            site.home.highlights.map((item, i) => (
              <div class={`group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] p-5 backdrop-blur-sm transition-all duration-300 hover:border-cyan-500/20 hover:shadow-[0_0_30px_rgba(6,182,212,0.06)] delay-${i + 4}`}>
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-cyan-500/[0.04] to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
                <div class="relative">
                  <p class="text-3xl font-bold gradient-text">{item.value}</p>
                  <p class="mt-1 text-sm text-[var(--muted)]">{item.label}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </Container>

  <!-- Featured Projects -->
  <Container className="pb-20">
    <SectionTitle
      title="Featured Projects"
      subtitle="Selección de entregas con foco en arquitectura, rendimiento y mantenibilidad."
    />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project) => <ProjectCard project={project.data} slug={project.slug} />)}
    </div>
  </Container>
</BaseLayout>
