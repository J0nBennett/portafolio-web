---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Button from "../components/ui/Button.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import site from "../data/site.json";
import PostCard from "../components/writing/PostCard.astro";
import skills from "../data/skills.json";

const posts = await getCollection("posts");
const latestPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projects = await getCollection("projects");
const featured = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const impactMetrics = [
  { value: "95+", label: "Lighthouse Score", icon: "⚡" },
  { value: "500+", label: "Tests Automatizados", icon: "🧪" },
  { value: "4+", label: "Años en IT", icon: "📅" },
  { value: "3", label: "Sistemas Bancarios", icon: "🏦" },
];

const skillIcons: Record<string, string> = {
  "QA & Automation": "🔬",
  "AI Stack & Workflows": "🤖",
  "Development & DB": "💻",
  "DevOps & Tools": "⚙️",
};
---

<BaseLayout title={`${site.siteName} | Inicio`} description={site.description} image="/og/home.png">
  <!-- Hero -->
  <Container className="pt-12 pb-12 sm:pt-28 sm:pb-20">
    <section class="relative">
      <!-- Decorative orbs -->
      <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-cyan-500/10 blur-[100px] animate-float"></div>
      <div class="pointer-events-none absolute -left-16 top-32 h-56 w-56 rounded-full bg-violet-500/10 blur-[80px] animate-float delay-3"></div>

      <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-center">
        <!-- Left: Text content -->
        <div>
          <!-- Availability + Role Badge -->
          <div class="flex flex-wrap items-center gap-3 animate-fade-in-up">
            <span class="availability-badge">
              <span class="availability-dot"></span>
              Disponible para proyectos
            </span>
            <p class="inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-4 py-1.5 text-xs sm:text-sm text-cyan-400">
              <span class="leading-tight">{site.roles[0]}</span>
            </p>
          </div>

          <h1 class="mt-6 text-3xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl animate-fade-in-up delay-1">
            <span class="text-[var(--text-heading)]">Hola, soy </span>
            <span class="gradient-text">{site.author}</span>
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-relaxed text-[var(--muted)] animate-fade-in-up delay-2">
            {site.tagline}
          </p>

          <!-- How I work -->
          <div class="mt-8 animate-fade-in-up delay-3">
            <p class="text-sm font-semibold text-[var(--text-heading)] uppercase tracking-wider">Cómo trabajo</p>
            <ul class="mt-3 space-y-2 text-sm text-[var(--muted)]">
              {site.home.differentiators.map((item: string) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3 animate-fade-in-up delay-4">
            <Button href={site.home.primaryCta.href} className="w-full sm:w-auto text-center">{site.home.primaryCta.label}</Button>
            <Button href="/cv.pdf" variant="secondary" className="w-full sm:w-auto text-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Descargar CV
            </Button>
          </div>

          <!-- Focus areas -->
          <div class="mt-8 flex flex-wrap gap-2 animate-fade-in-up delay-5">
            {site.focusAreas.map((area: string) => (
              <span class="rounded-lg border border-white/[0.06] bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-[var(--muted)] transition-colors duration-200 hover:border-cyan-500/20 hover:text-cyan-400">
                {area}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Impact Metrics -->
        <div class="grid grid-cols-2 gap-3 sm:gap-4 animate-fade-in-up delay-4">
          {
            impactMetrics.map((item, i) => (
              <div class={`group relative overflow-hidden rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 sm:p-6 backdrop-blur-sm transition-all duration-300 hover:border-cyan-500/20 hover:shadow-[0_0_30px_rgba(6,182,212,0.06)]`}>
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-cyan-500/[0.04] to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
                <div class="relative">
                  <span class="text-2xl mb-2 block">{item.icon}</span>
                  <p class="text-2xl sm:text-3xl font-bold gradient-text" data-count={item.value}>{item.value}</p>
                  <p class="mt-1 text-xs sm:text-sm text-[var(--muted)]">{item.label}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </Container>

  <!-- Skills Bento Grid -->
  <Container className="pb-20">
    <div class="scroll-reveal rounded-3xl border border-white/[0.06] bg-white/[0.02] p-6 sm:p-10 overflow-hidden relative">
      <div class="pointer-events-none absolute -right-24 -bottom-24 h-64 w-64 rounded-full bg-blue-500/5 blur-[80px]"></div>
      
      <div class="relative">
        <h2 class="text-2xl font-bold text-[var(--text-heading)] sm:text-3xl">Expertise & Skills</h2>
        <p class="mt-3 text-[var(--muted)] max-w-2xl">
          Dominio técnico enfocado en automatización de calidad, desarrollo ágil y soluciones asistidas por IA.
        </p>

        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {skills.map((skillGroup: { category: string; items: string[] }, idx: number) => (
            <div class={`bento-item scroll-reveal stagger-${idx + 1}`}>
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xl">{skillIcons[skillGroup.category] || "🔧"}</span>
                <h3 class="text-xs font-semibold text-cyan-400 uppercase tracking-widest">{skillGroup.category}</h3>
              </div>
              <ul class="flex flex-wrap gap-2">
                {skillGroup.items.map((skill: string) => (
                  <li class="rounded-md border border-white/[0.06] bg-white/[0.04] px-2.5 py-1 text-xs text-[var(--muted)] transition-all duration-200 hover:border-cyan-500/20 hover:text-cyan-400 hover:bg-cyan-500/5">
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Container>

  <!-- Featured Projects -->
  <Container className="pb-24">
    <div class="scroll-reveal">
      <SectionTitle
        title="Proyectos Destacados"
        subtitle="Selección de entregas con foco en arquitectura, rendimiento y mantenibilidad."
      />
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project, i) => (
        <div class={`scroll-reveal stagger-${i + 1}`}>
          <ProjectCard project={project.data} slug={project.slug} />
        </div>
      ))}
    </div>
    <div class="mt-12 flex justify-center scroll-reveal">
      <Button href="/projects" variant="secondary" className="group">
        Ver todos los proyectos
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </Button>
    </div>
  </Container>

  <!-- Latest Writing -->
  <Container className="pb-24">
    <div class="scroll-reveal">
      <SectionTitle
        title="Últimos Artículos"
        subtitle="Explorando las fronteras del testing, la IA y el desarrollo moderno."
      />
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post, i) => (
        <div class={`scroll-reveal stagger-${i + 1}`}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </Container>

  <!-- Connect CTA -->
  <Container className="pb-32">
    <div class="scroll-reveal-scale relative overflow-hidden rounded-3xl bg-gradient-to-br from-cyan-600/20 via-blue-600/15 to-violet-600/20 px-8 py-16 text-center sm:px-16 sm:py-24 border border-white/10">
      <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
      <!-- Floating orbs -->
      <div class="pointer-events-none absolute top-10 left-10 h-32 w-32 rounded-full bg-cyan-500/10 blur-[60px] animate-float"></div>
      <div class="pointer-events-none absolute bottom-10 right-10 h-40 w-40 rounded-full bg-violet-500/10 blur-[60px] animate-float delay-3"></div>
      
      <div class="relative z-10">
        <span class="availability-badge mx-auto mb-6">
          <span class="availability-dot"></span>
          Disponible para nuevos proyectos
        </span>
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          ¿Listo para elevar la calidad de tu producto?
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-cyan-100/80">
          Actualmente disponible para nuevos desafíos en QA Automation, Oracle APEX o consultoría técnica.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <Button href="/contact" size="lg">Hablemos ahora</Button>
          <Button href="mailto:jonbennettpy@gmail.com" variant="secondary" size="lg">
            Enviar email
          </Button>
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
