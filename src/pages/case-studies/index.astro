---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import Card from "../../components/ui/Card.astro";
import { withBasePath } from "../../utils/url";

const studies = (await getCollection("case-studies")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const basePath = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Case Studies | Portfolio"
  description="Case studies con decisiones técnicas y resultados."
  image="/og/case-studies.png"
>
  <Container className="py-16 sm:py-20">
    <SectionTitle
      as="h1"
      title="Case Studies"
      subtitle="Análisis de contexto, decisiones técnicas y resultados medibles."
    />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        studies.map((study) => (
          <Card>
            {study.data.thumbnail && (
              <div class="mb-4 overflow-hidden rounded-lg">
                <img
                  src={withBasePath(study.data.thumbnail, basePath)}
                  alt={`${study.data.title} thumbnail`}
                  class="h-32 w-full border border-white/[0.06] object-cover rounded-lg transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  width="1200"
                  height="630"
                />
              </div>
            )}
            <p class="text-xs text-[var(--muted)]">{study.data.date.toLocaleDateString("en-US")}</p>
            <h3 class="mt-2 text-lg font-semibold text-[var(--text-heading)]">
              <a class="focus-ring transition-colors hover:text-cyan-400" href={withBasePath(`/case-studies/${study.slug}/`, basePath)}>
                {study.data.title}
              </a>
            </h3>
            <p class="mt-3 text-sm text-[var(--muted)] leading-relaxed">{study.data.summary}</p>
          </Card>
        ))
      }
    </div>
  </Container>
</BaseLayout>
