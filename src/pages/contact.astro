---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import site from "../data/site.json";
import socials from "../data/socials.json";
---

<BaseLayout title="Contact | Portfolio" description="Canales de contacto profesional.">
  <Container className="py-14">
    <SectionTitle
      as="h1"
      title="Contact"
      subtitle="Disponible para colaborar en proyectos de ingeniería, calidad y automatización."
    />
    <Card className="max-w-2xl">
      <p class="text-[var(--muted)]">Email</p>
      <p class="mb-5 mt-1 text-lg font-medium">{site.email}</p>
      <Button href={`mailto:${site.email}`}>Send Email</Button>
      <ul class="mt-8 flex flex-wrap gap-3">
        {
          socials.map((social) => (
            <li>
              <a
                class="focus-ring inline-flex rounded-md border border-[var(--border)] px-3 py-2 text-sm hover:border-[var(--muted)]"
                target="_blank"
                rel="noreferrer"
                href={social.href}
              >
                {social.label}
              </a>
            </li>
          ))
        }
      </ul>
    </Card>
  </Container>
</BaseLayout>
