---
interface Props {
  title: string;
  subtitle?: string;
  as?: "h1" | "h2";
}

const { title, subtitle, as = "h2" } = Astro.props as Props;
const HeadingTag = as;
---

<div class="mb-10">
  <HeadingTag class="text-2xl font-bold tracking-tight sm:text-3xl">
    <span class="gradient-text">{title}</span>
  </HeadingTag>
  {subtitle && (
    <p class="mt-3 max-w-2xl text-[var(--muted)] leading-relaxed">{subtitle}</p>
  )}
  <div class="mt-4 h-1 w-16 rounded-full bg-gradient-to-r from-cyan-500 to-blue-600"></div>
</div>
