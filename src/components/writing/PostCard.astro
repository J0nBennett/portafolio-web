---
import { withBasePath } from "../../utils/url";

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      date: Date;
      summary: string;
    };
  };
}

const { post } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 transition-all duration-300 hover:border-cyan-500/20 hover:bg-white/[0.04] hover:shadow-[0_0_30px_rgba(6,182,212,0.06)]">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-cyan-500/[0.04] to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
  
  <div class="relative flex flex-col h-full">
    <time datetime={post.data.date.toISOString()} class="text-xs font-medium text-[var(--muted)]">
      {post.data.date.toLocaleDateString("es-PY", {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
    </time>
    
    <h3 class="mt-3 text-xl font-bold text-[var(--text-heading)] transition-colors group-hover:text-cyan-400">
      <a class="focus-ring" href={withBasePath(`/writing/${post.slug}/`, basePath)}>
        <span class="absolute inset-0"></span>
        {post.data.title}
      </a>
    </h3>
    
    <p class="mt-3 flex-1 text-sm leading-relaxed text-[var(--muted)]">
      {post.data.summary}
    </p>
    
    <div class="mt-6 flex items-center text-xs font-semibold uppercase tracking-wider text-cyan-400 opacity-0 transition-all duration-300 transform translate-x-[-10px] group-hover:opacity-100 group-hover:translate-x-0">
      Leer más
      <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
  </div>
</article>
