---
import site from "../../data/site.json";
import Container from "./Container.astro";
import { withBasePath } from "../../utils/url";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/case-studies", label: "Case Studies" },
  { href: "/writing", label: "Writing" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const basePath = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-20 border-b border-[var(--border)]/80 bg-[var(--bg)]/90 backdrop-blur">
  <Container className="flex items-center justify-between py-4">
    <a href={withBasePath("/", basePath)} class="focus-ring text-sm font-semibold tracking-wide">{site.siteName}</a>
    <nav aria-label="Principal">
      <ul class="flex flex-wrap items-center gap-4 text-sm text-[var(--muted)]">
        {
          navItems.map((item) => (
            <li>
              <a href={withBasePath(item.href, basePath)} class="focus-ring hover:text-[var(--text)] transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>
</header>
