---
import site from "../../data/site.json";
import Container from "./Container.astro";
import { withBasePath } from "../../utils/url";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/case-studies", label: "Case Studies" },
  { href: "/writing", label: "Writing" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const basePath = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-20 border-b border-white/[0.06] bg-[#0a0a0f]/80 backdrop-blur-xl">
  <Container className="flex items-center justify-between py-4">
    <a href={withBasePath("/", basePath)} class="focus-ring group flex items-center gap-2">
      <!-- Logo mark -->
      <span class="flex h-7 w-7 sm:h-8 sm:w-8 items-center justify-center rounded-lg bg-gradient-to-br from-cyan-500 to-blue-600 text-xs sm:text-sm font-bold text-white shadow-lg shadow-cyan-500/20">
        JC
      </span>
      <span class="text-xs sm:text-sm font-semibold tracking-wide text-[var(--text-heading)] transition-colors group-hover:text-cyan-400">
        {site.author}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav aria-label="Principal" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={withBasePath(item.href, basePath)}
                class="focus-ring relative px-3 py-2 text-sm text-[var(--muted)] transition-colors duration-200 hover:text-[var(--text-heading)]"
              >
                {item.label}
                <span class="absolute inset-x-3 -bottom-px h-px scale-x-0 bg-gradient-to-r from-cyan-500 to-blue-500 transition-transform duration-300 group-hover:scale-x-100" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="focus-ring flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 text-[var(--muted)] transition hover:border-cyan-500/30 hover:text-[var(--text-heading)] md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </Container>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="overflow-hidden bg-[#0a0a0f]/95 backdrop-blur-xl md:hidden transition-[max-height] duration-300 ease-in-out" style="max-height: 0">
    <Container>
      <nav class="py-6">
        <ul class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={withBasePath(item.href, basePath)}
                  class="focus-ring block rounded-xl px-4 py-3 text-base text-[var(--muted)] transition-colors hover:bg-white/5 hover:text-[var(--text-heading)]"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </Container>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu") as HTMLElement | null;
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener("click", () => {
      const isOpen = parseFloat(menu.style.maxHeight) > 0;
      if (isOpen) {
        menu.style.maxHeight = "0px";
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      } else {
        menu.style.maxHeight = menu.scrollHeight + "px";
        iconOpen.classList.add("hidden");
        iconClose.classList.remove("hidden");
        btn.setAttribute("aria-expanded", "true");
      }
    });
  }
</script>
