---
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";
import { withBasePath } from "../../utils/url";

interface ProjectData {
  title: string;
  summary: string;
  tags: string[];
  stack: string[];
  links: {
    repo: string;
    demo: string;
  };
  thumbnail?: string;
  featured: boolean;
  date: Date;
}

interface Props {
  project: ProjectData;
  slug: string;
}

const { project, slug } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<Card className="h-full">
  <div class="flex h-full flex-col gap-4">
    {project.thumbnail && (
        <img
        src={withBasePath(project.thumbnail, basePath)}
        alt={`${project.title} thumbnail`}
        class="h-36 w-full rounded-lg border border-[var(--border)] object-cover"
        loading="lazy"
        decoding="async"
        width="1200"
        height="630"
      />
    )}
    <div class="flex items-center justify-between gap-3">
      <h3 class="text-lg font-semibold">
        <a class="focus-ring hover:underline" href={withBasePath(`/projects/${slug}/`, basePath)}>{project.title}</a>
      </h3>
      {project.featured && <Badge label="Featured" />}
    </div>
    <p class="text-sm text-[var(--muted)]">{project.summary}</p>
    <ul class="flex flex-wrap gap-2">
      {
        project.tags.map((tag) => (
          <li class="rounded-md bg-neutral-100 px-2 py-1 text-xs text-neutral-700">{tag}</li>
        ))
      }
    </ul>
    <p class="mt-auto text-xs text-[var(--muted)]">Stack: {project.stack.join(" • ")}</p>
    <div class="flex gap-4 text-sm">
      <a href={project.links.repo} target="_blank" rel="noreferrer" class="focus-ring hover:underline">
        Repo
      </a>
      <a href={project.links.demo} target="_blank" rel="noreferrer" class="focus-ring hover:underline">
        Demo
      </a>
    </div>
  </div>
</Card>
