---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import { withBasePath } from "../utils/url";

interface Props {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  image?: string;
  sectionOgImage?: string;
  backUrl?: string;
  backLabel?: string;
}

const { 
  title, 
  summary, 
  date, 
  tags, 
  image, 
  sectionOgImage = "/og/home.png",
  backUrl = "/case-studies",
  backLabel = "Volver a Estudios"
} = Astro.props;

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} | Portfolio`} description={summary} image={image || sectionOgImage}>
  <!-- Decorative background elements -->
  <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
    <div class="absolute -right-24 top-0 h-96 w-96 rounded-full bg-cyan-500/5 blur-[120px]"></div>
    <div class="absolute -left-24 bottom-0 h-96 w-96 rounded-full bg-violet-500/5 blur-[120px]"></div>
  </div>

  <Container className="relative z-10 py-12 sm:py-20">
    <!-- Back Button -->
    <a 
      href={withBasePath(backUrl, basePath)} 
      class="back-button-glow group mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-[var(--muted)] transition-all hover:border-cyan-500/30 hover:text-cyan-400"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      {backLabel}
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3">
        <time datetime={date.toISOString()} class="text-sm font-medium text-cyan-500/80">
          {date.toLocaleDateString("en-US", { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span class="text-sm text-[var(--muted)]">Lectura de 5 min</span>
      </div>

      <h1 class="mt-6 max-w-4xl text-4xl font-extrabold tracking-tight leading-[1.15] text-[var(--text-heading)] sm:text-5xl lg:text-6xl animate-fade-in-up">
        {title}
      </h1>

      <p class="mt-8 max-w-3xl text-lg leading-8 text-[var(--muted)] sm:text-xl animate-fade-in-up delay-1">
        {summary}
      </p>

      <ul class="mt-8 flex flex-wrap gap-2 animate-fade-in-up delay-2">
        {
          tags.map((tag) => (
            <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-cyan-400/90 shadow-sm backdrop-blur-md">
              {tag}
            </li>
          ))
        }
      </ul>
    </header>

    {image && (
      <div class="mb-16 overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-2 shadow-2xl animate-fade-in-up delay-3">
        <img 
          src={withBasePath(image, basePath)} 
          alt={`${title} thumbnail`} 
          class="aspect-video w-full rounded-xl object-cover" 
          loading="eager" 
          width="1200" 
          height="630" 
        />
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_250px] gap-12">
      <article class="prose max-w-none animate-fade-in-up delay-4">
        <slot />
      </article>

      <!-- Sidebar / Info -->
      <aside class="hidden lg:block space-y-8 animate-fade-in-up delay-5">
        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 sticky top-24">
          <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--text-heading)]">Detalles</h3>
          <dl class="mt-4 space-y-4">
            <div>
              <dt class="text-xs text-[var(--muted)]">Publicado</dt>
              <dd class="mt-1 text-sm font-medium text-[var(--text-heading)]">{date.toLocaleDateString()}</dd>
            </div>
            <div>
              <dt class="text-xs text-[var(--muted)]">Tags</dt>
              <dd class="mt-1 flex flex-wrap gap-1">
                {tags.slice(0, 3).map(tag => <span class="text-xs text-cyan-400/80">#{tag}</span>)}
              </dd>
            </div>
          </dl>
          <hr class="my-6 border-white/5" />
          <button class="w-full rounded-xl bg-gradient-to-r from-cyan-600 to-blue-600 px-4 py-2.5 text-xs font-bold text-white transition-transform hover:scale-[1.02] active:scale-[0.98]">
            Compartir artículo
          </button>
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>
