---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import { withBasePath } from "../utils/url";

interface Props {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  image?: string;
  sectionOgImage?: string;
}

const { title, summary, date, tags, image, sectionOgImage = "/og/home.png" } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} | Portfolio`} description={summary} image={image || sectionOgImage}>
  <Container className="py-12 sm:py-14">
    <header class="mb-8 border-b border-[var(--border)] pb-6 sm:pb-7">
      <p class="text-sm text-[var(--muted)]">{date.toLocaleDateString("en-US")}</p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold tracking-tight leading-tight sm:text-4xl">{title}</h1>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--muted)] sm:text-base">{summary}</p>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          tags.map((tag) => <li class="rounded bg-neutral-100 px-2 py-1 text-xs text-neutral-700">{tag}</li>)
        }
      </ul>
    </header>
    {image && (
      <div class="mb-7 overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)]">
        <img src={withBasePath(image, basePath)} alt={`${title} thumbnail`} class="h-auto w-full object-cover" loading="eager" width="1200" height="630" />
      </div>
    )}
    <article class="prose prose-neutral max-w-3xl text-[15px] leading-7 prose-headings:tracking-tight prose-h2:mt-10 prose-h2:text-2xl prose-h2:leading-tight prose-p:text-[15px] prose-p:leading-7 sm:text-base">
      <slot />
    </article>
  </Container>
</BaseLayout>
