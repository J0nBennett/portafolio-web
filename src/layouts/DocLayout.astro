---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import { withBasePath } from "../utils/url";

interface Props {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  image?: string;
  sectionOgImage?: string;
}

const { title, summary, date, tags, image, sectionOgImage = "/og/home.png" } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} | Portfolio`} description={summary} image={image || sectionOgImage}>
  <Container className="py-14 sm:py-18">
    <header class="mb-10 border-b border-white/[0.06] pb-8">
      <p class="text-sm text-[var(--muted)]">{date.toLocaleDateString("en-US")}</p>
      <h1 class="mt-3 max-w-4xl text-3xl font-bold tracking-tight leading-tight text-[var(--text-heading)] sm:text-4xl">
        {title}
      </h1>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--muted)] sm:text-base">{summary}</p>
      <ul class="mt-5 flex flex-wrap gap-2">
        {
          tags.map((tag) => <li class="rounded-lg border border-white/[0.06] bg-white/[0.03] px-2.5 py-1 text-xs text-[var(--muted)]">{tag}</li>)
        }
      </ul>
    </header>
    {image && (
      <div class="mb-8 overflow-hidden rounded-xl border border-white/[0.06]">
        <img src={withBasePath(image, basePath)} alt={`${title} thumbnail`} class="h-auto w-full object-cover" loading="eager" width="1200" height="630" />
      </div>
    )}
    <article class="prose max-w-3xl text-[15px] leading-7 prose-headings:tracking-tight prose-h2:mt-10 prose-h2:text-2xl prose-h2:leading-tight prose-p:text-[15px] prose-p:leading-7 sm:text-base">
      <slot />
    </article>
  </Container>
</BaseLayout>
