---
import "../styles/globals.css";
import site from "../data/site.json";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Seo from "../components/seo/Seo.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { title = site.siteName, description = site.description, image, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <Seo title={title} description={description} image={image} canonical={canonical} />
  </head>
  <body>
    <a href="#main-content" class="focus-ring absolute left-4 top-4 z-30 -translate-y-20 rounded bg-[var(--surface-solid)] px-3 py-2 text-sm transition focus:translate-y-0">
      Skip to content
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
